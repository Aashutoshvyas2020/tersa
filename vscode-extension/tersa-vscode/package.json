{
  "name": "tersa-vscode",
  "displayName": "Tersa",
  "description": "Practical VS Code companion for Tersa with project-aware launch behavior and a real Control Center.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:tersa.start",
    "onCommand:tersa.startInWorkspaceRoot",
    "onCommand:tersa.openDocs",
    "onCommand:tersa.openSetupDocs",
    "onCommand:tersa.openWorkspaceProfile",
    "onCommand:tersa.openControlCenter",
    "onCommand:tersa.newChat",
    "onCommand:tersa.openChat",
    "onCommand:tersa.resumeSession",
    "onCommand:tersa.abortChat",
    "onView:tersa.controlCenter",
    "onView:tersa.chat"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tersa.start",
        "title": "Tersa: Launch in Terminal",
        "category": "Tersa"
      },
      {
        "command": "tersa.startInWorkspaceRoot",
        "title": "Tersa: Launch in Workspace Root",
        "category": "Tersa"
      },
      {
        "command": "tersa.openDocs",
        "title": "Tersa: Open Repository",
        "category": "Tersa"
      },
      {
        "command": "tersa.openSetupDocs",
        "title": "Tersa: Open Setup Guide",
        "category": "Tersa"
      },
      {
        "command": "tersa.openWorkspaceProfile",
        "title": "Tersa: Open Workspace Profile",
        "category": "Tersa"
      },
      {
        "command": "tersa.openControlCenter",
        "title": "Tersa: Open Control Center",
        "category": "Tersa"
      },
      {
        "command": "tersa.newChat",
        "title": "Tersa: New Chat",
        "category": "Tersa"
      },
      {
        "command": "tersa.openChat",
        "title": "Tersa: Open Chat Panel",
        "category": "Tersa"
      },
      {
        "command": "tersa.resumeSession",
        "title": "Tersa: Resume Session",
        "category": "Tersa"
      },
      {
        "command": "tersa.abortChat",
        "title": "Tersa: Abort Generation",
        "category": "Tersa"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tersa",
          "title": "Tersa",
          "icon": "media/tersa.svg"
        }
      ]
    },
    "views": {
      "tersa": [
        {
          "id": "tersa.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "tersa.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tersa.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "Tersa",
      "properties": {
        "tersa.launchCommand": {
          "type": "string",
          "default": "tersa",
          "description": "Command run in the integrated terminal when launching Tersa."
        },
        "tersa.terminalName": {
          "type": "string",
          "default": "Tersa",
          "description": "Integrated terminal tab name for Tersa sessions."
        },
        "tersa.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched Tersa terminals."
        },
        "tersa.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Prompt for permission on each tool use (requires manual approval)",
            "Auto-approve file edits, prompt for other operations (recommended)",
            "Auto-approve all operations without prompting",
            "Read-only mode — no file modifications allowed"
          ],
          "description": "Permission mode for chat sessions. Controls which tool operations are auto-approved."
        }
      }
    },
    "themes": [
      {
        "label": "Tersa Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/Tersa-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node scripts/lint.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "tersa",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gitlawb/tersa"
  },
  "license": "MIT"
}
